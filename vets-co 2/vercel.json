{
  "version": 2,
  "name": "vets-co",
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/find-a-vet",
      "dest": "/index.html"
    },
    {
      "src": "/pet-health/emergency-vet-guide",
      "dest": "/emergency-vet-guide.html"
    },
    {
      "src": "/pet-health/find-a-specialist",
      "dest": "/find-a-specialist.html"
    },
    {
      "src": "/pet-insurance",
      "dest": "/best-pet-insurance.html"
    },
    {
      "src": "/vets/(.*)",
      "dest": "/vet-profile.html"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*)\\.(html|css|js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
